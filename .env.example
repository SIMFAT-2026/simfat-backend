# SIMFAT Backend Environment Variables
# ------------------------------------------------------------------
# Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/simfat
#
# MongoDB Atlas (recommended for remote environments / Oracle Cloud):
# MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/simfat?retryWrites=true&w=majorit>y&appName=Simfat
MONGODB_URI=mongodb://localhost:27017/simfat

# PostgreSQL (requerido para auth + scripts SQL evaluativos)
POSTGRES_URI=jdbc:postgresql://localhost:5432/simfat
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# API server port
SERVER_PORT=8081

# Allowed frontend origins (comma separated)
# Local examples: http://localhost:3000,http://localhost:4173
# Vercel example: https://simfat-frontend.vercel.app
FRONTEND_URL=http://localhost:3000,http://localhost:4173

# Domain defaults for MVP logic
DEFAULT_REFERENCE_HECTARES=100000
DEFAULT_LOSS_THRESHOLD=1.0
DEFAULT_HEAT_EVENTS_THRESHOLD=5
APP_SEED_ENABLED=true

# openEO integration through openeo-service
OPENEO_SERVICE_BASE_URL=http://localhost:8000
OPENEO_SERVICE_TIMEOUT_MS=8000
OPENEO_SYNC_ENABLED=true
OPENEO_SYNC_CRON=0 */15 * * * *
OPENEO_SYNC_PLACEHOLDER_VALUE_ENABLED=true

# Auth / JWT
# En produccion usa una clave fuerte (>= 32 bytes) y NO commiteada.
AUTH_JWT_SECRET=simfat-dev-secret-change-me-min-32-bytes-please123
AUTH_JWT_ACCESS_TTL_MINUTES=15
AUTH_JWT_REFRESH_TTL_DAYS=14
AUTH_JWT_ISSUER=simfat-backend

# Turnstile (opcional)
AUTH_TURNSTILE_ENABLED=false
AUTH_TURNSTILE_SECRET_KEY=disabled
AUTH_TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# Rate limiting auth
AUTH_RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_FORGOT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_FORGOT_WINDOW_SECONDS=600

# Reset password
AUTH_PASSWORD_RESET_TTL_MINUTES=30
